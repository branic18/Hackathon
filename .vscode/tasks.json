{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: watch - vulnerability-scanner",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}/vulnerability-scanner"
      },
      "isBackground": true,
      "problemMatcher": [
        "$tsc-watch"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
